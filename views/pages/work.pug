extends ../base.pug 

block variables
  - var template = "work"

block content 
  main.work
    .work__wrapper 

      section.work__heading
        .work__heading__wrapper 
          h1.work__heading__text(data-midTitle) Work
          p.work__heading__subtext(data-subTitle)
            | Hands-on experience in containerization, CI/CD automation, 
            | and cloud-native technologies. Check out my 
            | projects for experiments.

      section.work__body
        .work__experiences 
          ul.work__experiences__wrapper 
            li.work__experience 
              p.work__experience__title(data-first-letter="D" data-other-letters="evOps") DevOps
              p.work__experience__subdetails DevOps & Cloud Infrastructure Practitioner (2024 – Present)
              .work__experience__expand
                p.work__experience__details 
                  | Engineered optimized Dockerfiles leveraging layer caching and strategic COPY ordering.
                  | Designed multi-container environments using Docker Compose. Automated CI/CD
                  | pipelines with GitHub Actions, reducing manual deployment to near zero.
                .work__experience__extradetails
                  p.work__experience__stack Docker, Kubernetes, GitHub Actions, AWS, IBM Cloud
                  p.work__experience__role DevOps & Cloud Infrastructure Practitioner (2024 – Present)

            li.work__experience 
              p.work__experience__title(data-first-letter="C" data-other-letters="loud" data-long) Cloud
              p.work__experience__subdetails Cloud & Linux Deployment Engineer (2023 – 2024)
              .work__experience__expand
                p.work__experience__details 
                  | Deployed web projects on Netlify and Vercel with zero-downtime releases. 
                  | Administered Linux systems (Ubuntu/CentOS) for security and stability.
                  | Completed 5 IBM Cloud certifications in Containers, Kubernetes, and Istio.
                .work__experience__extradetails
                  p.work__experience__stack 
                    | Linux, Bash, Netlify, Vercel,
                    | IBM Cloud, OpenShift 
                  p.work__experience__role Cloud & Linux Deployment Engineer (2023 – 2024)