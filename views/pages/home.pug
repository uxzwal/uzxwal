extends ../base.pug 

append variables
  - var template = "home"

block content 
  main.home
    .home__wrapper 

      section.home__heading
        .home__heading__wrapper 
          h1.home__heading__text(data-bigTitle)
            span.home__heading__serif(data-alt="Ujj") Ujjwal
            span.home__heading__sans(data-alt="Wal") Kumar

      section.home__body 
        .home__body__wrapper
          p.home__text__01(data-subTitle) 
            | DevOps Engineer — Containers | CI/CD | Cloud Infrastructure | Linux 
          p.home__text__02(data-suburbTitle) 
            | Passionate about streamlining deployment pipelines, optimizing container performance, and applying modern DevOps practices to deliver reliable, scalable infrastructure solutions.

      section.home__canvas     
        .home__canvas__wrapper    
          figure.home__canvas__illustration
