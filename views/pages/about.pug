extends ../base.pug 

block variables
  - var template = "about"

block content
  main.about
    .about__wrapper 

      .about__sections__wrapper
        section.about_me
          .about__me__wrapper
            p.about__text Ujjwal Kumar 
            figure.about__media
              video.about__media__image(src="images/goody.webm" alt="Ujjwal Kumar" autoplay poster) 
            figure.about__media
              img.about__media__image(src="images/goody.webp" alt="web portal") 
            p.about__text DevOps
            p.about__text Engineer 
            p.about__text From 
            figure.about__media
              img.about__media__image(src="images/flag.jpg" alt="Indian Flag")
            p.about__text  India

        section.about__mobile
          .about__mobile__wrapper
            figure.about__mobile__media(data-portal-image)
              video.about__mobile__image(src="images/goody.webm" alt="Ujjwal Kumar" autoplay poster)

      section.about__main 
        section.about__heading
          .about__heading__wrapper 
            h1.about__heading__text(data-midTitle) About
            p.about__heading__subtext(data-subTitle)
              | When I'm not writing Dockerfiles, I'm probably 
              | automating CI/CD pipelines or exploring 
              | cloud-native technologies
