extends ../base.pug 

block variables
  - var template = "about"

block content
  main.about
    .about__wrapper 

      .about__sections__wrapper
        section.about_me
          .about__me__wrapper
            p.about__text Ujjwal Kumar 
            figure.about__media
              img.about__media__image(src="images/ujjwal_1.png" alt="Ujjwal Kumar") 
            figure.about__media
              img.about__media__image(src="images/ujjwal_2.png" alt="Ujjwal Kumar DevOps") 
            p.about__text DevOps
            p.about__text Engineer 
            p.about__text From 
            figure.about__media.about__flag--waving
              img.about__media__image(src="images/flag.png" alt="Indian Flag")
            p.about__text  India

        section.about__mobile
          .about__mobile__wrapper
            figure.about__mobile__media(data-portal-image)
              img.about__mobile__image(src="images/ujjwal_1.png" alt="Ujjwal Kumar")

      section.about__main 
        section.about__heading
          .about__heading__wrapper 
            h1.about__heading__text(data-midTitle) About
            p.about__heading__subtext(data-subTitle)
              | When I'm not writing Dockerfiles, I'm probably 
              | automating CI/CD pipelines or exploring 
              | cloud-native technologies
