block variables 
  - const title = "Ujjwal Kumar -- DevOps Engineer"
  - const description = "DevOps Engineer — Containers | CI/CD | Cloud Infrastructure | Linux"
  - const isStaticExport = typeof staticExport === "boolean" ? staticExport : false
  - const staticBasePath = typeof basePath === "string" && basePath.length > 0 ? basePath : "/"
  - const normalizedBasePath = staticBasePath.endsWith("/") ? staticBasePath : `${staticBasePath}/`
  - const homeHref = isStaticExport ? "index.html" : "/"
  - const workHref = isStaticExport ? "work.html" : "/work"
  - const aboutHref = isStaticExport ? "about.html" : "/about"
  - const projectsHref = isStaticExport ? "projects.html" : "/projects"
  - const contactHref = isStaticExport ? "contact.html" : "/contact"
  - const appleTouchIcon = `${normalizedBasePath}apple-touch-icon.png`
  - const favicon32 = `${normalizedBasePath}favicon-32x32.png`
  - const favicon16 = `${normalizedBasePath}favicon-16x16.png`
  - const manifestPath = `${normalizedBasePath}site.webmanifest`
  - const safariPinnedTab = `${normalizedBasePath}safari-pinned-tab.svg`
  - const image = `${normalizedBasePath}images/preview.jpg`
  - const mainScriptPath = `${normalizedBasePath}main.js`
  - const site = "@uxzwalll"


doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    base(href=normalizedBasePath)

    title #{title}

    meta(name="description" content="DevOps Engineer — Containers | CI/CD | Cloud Infrastructure | Linux")

    link(rel="apple-touch-icon" sizes="180x180" href=appleTouchIcon)
    link(rel="icon" type="image/png" sizes="32x32" href=favicon32)
    link(rel="icon" type="image/png" sizes="16x16" href=favicon16)
    link(rel="manifest" href=manifestPath crossorigin="use-credentials")
    link(rel="mask-icon" href=safariPinnedTab color="#ff3a00")
    meta(name="msapplication-TileColor" content="#000000")
    meta(name="theme-color" content="#ffffff")

    meta(property="og:type" content="website")
    meta(property="og:title" content=title)
    meta(property="og:description" content=description)
    meta(property="og:image" content=image ? image: "")

    meta(property="twitter:card" content="summary_large_image")
    meta(property="twitter:title" content=title)
    meta(property="twitter:description" content=description)
    meta(property="twitter:image" content=image ? image: "")
    meta(property="twitter:site" content=site)

    link(href="https://api.fontshare.com/v2/css?f[]=clash-display@1&display=swap" rel="stylesheet")
    link(href="https://fonts.cdnfonts.com/css/manuscribe-free" rel="stylesheet")

  body
    style
      include ../public/main.css

    include ./partials/preloader
    include ./partials/header
    include ./partials/navigation

    .content#content(data-template=template)
      block content

      if template === "home" || template === "about" || template === "contact"
        include ./partials/footer
    script.
      window.preloadables = !{JSON.stringify(preloadables).replace(/<\//g, "<\\/")}
      window.__STATIC_EXPORT__ = !{JSON.stringify(isStaticExport)}
    script(src=mainScriptPath) 
